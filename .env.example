# ─────────────────────────────────────────────────────────────
# WordPress Migration Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The script will auto-load .env if it exists in the same
# directory as wpmigration.sh. Any values left blank will
# be prompted for interactively at runtime.
# ─────────────────────────────────────────────────────────────

# ── Destination Server (SSH) ─────────────────────────────────
NEW_SSH_HOST=""
NEW_SSH_PORT="22"
NEW_SSH_USER=""
# Auth: "key" or "password"
AUTH_METHOD="key"
# Only needed if AUTH_METHOD="password"
SSH_PASS=""
# Only needed if AUTH_METHOD="key" (default: ~/.ssh/id_rsa)
SSH_KEY_PATH=""

# ── Destination Paths & Ownership ────────────────────────────
NEW_WEB_PATH=""
NEW_WEB_USER="www-data"
NEW_WEB_GROUP="www-data"

# ── Destination Database ─────────────────────────────────────
NEW_DB_HOST="localhost"
NEW_DB_NAME=""
NEW_DB_USER=""
NEW_DB_PASS=""
NEW_TABLE_PREFIX=""

# ── URL Search-Replace (optional) ────────────────────────────
# Leave blank to skip. Only needed if domain changes.
OLD_URL=""
NEW_URL=""
